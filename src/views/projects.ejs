<%- include('partials/header') %>
    <main>
    <h1>Upcoming Service Projects</h1>
    
<% if (projects && projects.length> 0) { %>
    <ul>
        <% projects.forEach((project)=> { %>
            <li>
                <h2>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                </h2>

                <p>
                    <%= project.description %>
                </p>

                <p>
                    Organization:
                    <a href="/organization/<%= project.organization_id %>">
                        <%= project.organization_name %>
                    </a>
                </p>
            </li>
            <% }); %>
    </ul>
    <% } else { %>
        <p>No upcoming projects found.</p>
        <% } %>
    </main>
    <%- include('partials/footer') %>